BACKUP_DIR=/var/lib/dumbpad-backups
BACKUP_MASTER_KEY=base64-encoded-32-byte-key
BACKUP_MAX_BYTES=1073741824
# Source settings. For S3-backed production data, use a separate read-only
# source credential here. Do not copy this file into the app container.
STORAGE_BACKEND=s3
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=dumbpad-prod
S3_ACCESS_KEY=production-read-only-access-key
S3_SECRET_KEY=production-read-only-secret-key
S3_PREFIX=dumbpad-prod
# Required when STORAGE_BACKEND=s3. This is an independent backup repository
# and needs a credential that cannot access the production data bucket.
BACKUP_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=dumbpad-backup
BACKUP_S3_ACCESS_KEY=backup-only-access-key
BACKUP_S3_SECRET_KEY=backup-only-secret-key
BACKUP_S3_PREFIX=snapshots
