# DumbPad Environment Example
# Copy this file to `.env` and fill only the parts you use.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

PORT=3000
NODE_ENV=production
BASE_URL=http://localhost:3000

# Optional. Leave empty to disable PIN protection.
DUMBPAD_PIN=

# V1 personal authentication. Leave false until you have created a persistent
# host directory and securely generated AUTH_MASTER_KEY. The legacy PIN is
# used once during setup, then replaced by the password/TOTP flow.
AUTH_V2_ENABLED=false
AUTH_STATE_DIR=/var/lib/dumbpad-security
AUTH_MASTER_KEY=
AUTH_BOOTSTRAP_TOKEN=
AUTH_AUDIT_DIR=

# Keep this stable if you use shared links.
SHARE_SECRET=

# Local data directory.
DATA_DIR=./data

# Maximum bytes for a non-image article attachment uploaded with /file.
# Images keep their independent 50 MiB limit.
ASSET_MAX_FILE_BYTES=20971520

# Required only when running behind a trusted reverse proxy.
TRUST_PROXY=false
TRUSTED_PROXY_IPS=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# local: use DATA_DIR
# s3: use S3-compatible object storage
STORAGE_BACKEND=local

# legacy: single-file Thought storage, fine for local use
# split: per-object Thought/relation storage, recommended for S3
STORAGE_LAYOUT=legacy

# Required only when STORAGE_BACKEND=s3.
S3_ENDPOINT=https://s3-cn-east-1.qiniucs.com
S3_REGION=s3-cn-east-1
S3_BUCKET=dumbpad
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_PREFIX=dumbpad

# Used by the settings data-space picker. Usually keep the same root family as S3_PREFIX.
S3_SPACE_ROOT=dumbpad

# Space deletion, full local/S3 overwrite, and non-dry-run local imports are
# disabled by default. Keep false in normal operation; the V1 recovery flow
# will replace these legacy operations with archive-and-restore workflows.
DUMBPAD_ENABLE_DESTRUCTIVE_DATA_OPERATIONS=false
# Required in addition to the switch when using the legacy S3 delete CLI.
DUMBPAD_DESTRUCTIVE_S3_CONFIRM_PREFIX=

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------

# Chat/extraction model. Leave AI_API_KEY empty to use the noop provider.
AI_BASE_URL=https://example.com/v1
AI_API_KEY=
AI_CHAT_MODEL=deepseek-v4-flash

# Manual Thought insight. Uses AI_BASE_URL/AI_API_KEY unless these are set.
# AI_INSIGHT_MODEL must be explicit and different from AI_CHAT_MODEL.
AI_INSIGHT_BASE_URL=
AI_INSIGHT_API_KEY=
AI_INSIGHT_MODEL=
# Hard server-side cap for stored Insight Markdown (Chinese characters).
AI_INSIGHT_MAX_CHARS=800

# Embedding. Leave AI_EMBEDDING_API_KEY empty to skip real embeddings.
AI_EMBEDDING_BASE_URL=https://example.com/v1
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Relation rerank. Leave AI_RERANK_API_KEY empty to skip dedicated reranking.
AI_RERANK_BASE_URL=https://api.siliconflow.cn/v1
AI_RERANK_API_KEY=
AI_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Maximum concurrent AI meta reads while building relations (especially for S3).
AI_RELATION_META_READ_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Interactive AI Agent (optional; disabled by default)
# -----------------------------------------------------------------------------

# This is a separate, user-triggered read-only Agent model. It never falls back
# to AI_CHAT_MODEL or AI_INSIGHT_MODEL. Thought/Notepad saving still works when
# it is disabled or unavailable.
AI_AGENT_ENABLED=false
AI_AGENT_BASE_URL=https://example.com/v1
AI_AGENT_API_KEY=
AI_AGENT_MODEL=

# Hard server-side limits for the phase-A recall_context workflow.
AI_AGENT_MAX_STEPS=3
AI_AGENT_TIMEOUT_MS=45000
AI_AGENT_MAX_CONTEXT_CHARS=6000
AI_AGENT_MAX_TOOL_RESULTS=8
AI_AGENT_MAX_EXCERPT_CHARS=600
AI_AGENT_DAILY_RUN_LIMIT=50
AI_AGENT_EVENT_BUFFER_LIMIT=120
