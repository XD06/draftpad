# DumbPad Environment Example
# Copy this file to `.env` and fill only the parts you use.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

PORT=3000
NODE_ENV=production
BASE_URL=http://localhost:3000

# Optional. Leave empty to disable PIN protection.
DUMBPAD_PIN=

# Keep this stable if you use shared links.
SHARE_SECRET=

# Local data directory.
DATA_DIR=./data

# Required only when running behind a trusted reverse proxy.
TRUST_PROXY=false
TRUSTED_PROXY_IPS=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# local: use DATA_DIR
# s3: use S3-compatible object storage
STORAGE_BACKEND=local

# legacy: single-file Thought storage, fine for local use
# split: per-object Thought/relation storage, recommended for S3
STORAGE_LAYOUT=legacy

# Required only when STORAGE_BACKEND=s3.
S3_ENDPOINT=https://s3-cn-east-1.qiniucs.com
S3_REGION=s3-cn-east-1
S3_BUCKET=dumbpad
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_PREFIX=dumbpad

# Used by the settings data-space picker. Usually keep the same root family as S3_PREFIX.
S3_SPACE_ROOT=dumbpad

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------

# Chat/extraction model. Leave AI_API_KEY empty to use the noop provider.
AI_BASE_URL=https://example.com/v1
AI_API_KEY=
AI_CHAT_MODEL=deepseek-v4-flash

# Manual Thought insight. Uses AI_BASE_URL/AI_API_KEY unless these are set.
# AI_INSIGHT_MODEL must be explicit and different from AI_CHAT_MODEL.
AI_INSIGHT_BASE_URL=
AI_INSIGHT_API_KEY=
AI_INSIGHT_MODEL=

# Embedding. Leave AI_EMBEDDING_API_KEY empty to skip real embeddings.
AI_EMBEDDING_BASE_URL=https://example.com/v1
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Relation rerank. Leave AI_RERANK_API_KEY empty to skip dedicated reranking.
AI_RERANK_BASE_URL=https://api.siliconflow.cn/v1
AI_RERANK_API_KEY=
AI_RERANK_MODEL=BAAI/bge-reranker-v2-m3
