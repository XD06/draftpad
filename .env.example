# DumbPad Environment Example
# DumbPad 环境变量示例
#
# Copy this file to `.env` before running locally.
# 本地运行前请复制为 `.env`，不要把真实 `.env` 上传到 GitHub。

# -----------------------------------------------------------------------------
# Server / 服务
# -----------------------------------------------------------------------------

# CN: HTTP 服务监听端口。
# EN: Port used by the HTTP server.
PORT=3000

# CN: 运行环境。生产部署使用 production，本地开发可用 development。
# EN: Runtime environment. Use production for deployment and development locally.
NODE_ENV=production

# CN: 应用公开访问地址，用于生成分享链接和判断 HTTPS Cookie。
# EN: Public base URL, used for share links and secure-cookie decisions.
BASE_URL=http://localhost:3000

# CN: 页面和 PWA manifest 中显示的网站名称。
# EN: Site title displayed in pages and the PWA manifest.
SITE_TITLE=DumbPad

# CN: 用户数据目录。本地存储 backend 会读写这里。
# EN: User data directory. The local storage backend reads and writes here.
DATA_DIR=./data

# CN: 打开 WebSocket 调试日志。一般保持 false。
# EN: Enable WebSocket debug logs. Usually keep false.
DEBUG_WS=false

# CN: 打开 IP 提取调试日志。排查反向代理时可临时开启。
# EN: Enable IP-extraction debug logs. Useful when diagnosing reverse proxy setup.
DEBUG=false

# -----------------------------------------------------------------------------
# Security / 安全
# -----------------------------------------------------------------------------

# CN: 访问 PIN。4-10 位数字；留空表示不启用 PIN。
# EN: Access PIN. Must be 4-10 digits; leave empty to disable PIN protection.
DUMBPAD_PIN=

# CN: 分享链接签名密钥。留空时会回退到 DUMBPAD_PIN 或内置默认值；生产环境建议设置。
# EN: Secret used to sign share links. Falls back to DUMBPAD_PIN or a built-in default; set this in production.
SHARE_SECRET=

# CN: 登录 Cookie 有效期，单位小时。
# EN: Auth cookie lifetime in hours.
COOKIE_MAX_AGE=24

# CN: 最近打开文章 Cookie 有效期，单位天。
# EN: Recent-page/history cookie lifetime in days.
PAGE_HISTORY_COOKIE_AGE=365

# CN: 单个 IP 允许的 PIN 错误次数。
# EN: Maximum failed PIN attempts allowed per IP.
MAX_ATTEMPTS=5

# CN: PIN 错误次数过多后的锁定时间，单位分钟。
# EN: Lockout duration in minutes after too many failed PIN attempts.
LOCKOUT_TIME=15

# -----------------------------------------------------------------------------
# CORS / 跨域
# -----------------------------------------------------------------------------

# CN: 允许访问 API 的 Origin，多个值用英文逗号分隔；开发环境可用 *。
# EN: Allowed API origins, comma-separated. Use * for development only.
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Reverse Proxy / 反向代理
# -----------------------------------------------------------------------------

# CN: 是否信任反向代理传入的 X-Forwarded-For。只有在可信代理后部署时才设为 true。
# EN: Whether to trust X-Forwarded-For from reverse proxies. Enable only behind trusted proxies.
TRUST_PROXY=false

# CN: 可信代理 IP 列表，多个值用英文逗号分隔；TRUST_PROXY=true 时必须配置。
# EN: Trusted proxy IPs, comma-separated. Required when TRUST_PROXY=true.
TRUSTED_PROXY_IPS=

# -----------------------------------------------------------------------------
# Storage / 存储
# -----------------------------------------------------------------------------

# CN: 存储后端。local 使用 DATA_DIR；s3 使用 S3 兼容对象存储。
# EN: Storage backend. local uses DATA_DIR; s3 uses S3-compatible object storage.
STORAGE_BACKEND=local

# CN: 存储布局。legacy 兼容旧结构；split 将 Thought/关系等拆分成独立对象，推荐 S3 使用。
# EN: Storage layout. legacy keeps old structure; split stores thoughts/relations as separate objects and is recommended for S3.
STORAGE_LAYOUT=legacy

# -----------------------------------------------------------------------------
# S3-compatible Storage / S3 兼容对象存储
# -----------------------------------------------------------------------------

# CN: S3 兼容服务 endpoint，例如 AWS S3、Cloudflare R2、七牛 Kodo S3 API。
# EN: S3-compatible endpoint, such as AWS S3, Cloudflare R2, or Qiniu Kodo S3 API.
S3_ENDPOINT=https://s3-cn-east-1.qiniucs.com

# CN: S3 区域。
# EN: S3 region.
S3_REGION=s3-cn-east-1

# CN: S3 bucket 名称。
# EN: S3 bucket name.
S3_BUCKET=dumbpad

# CN: S3 Access Key。不要提交真实密钥。
# EN: S3 access key. Do not commit real credentials.
S3_ACCESS_KEY=your-access-key

# CN: S3 Secret Key。不要提交真实密钥。
# EN: S3 secret key. Do not commit real credentials.
S3_SECRET_KEY=your-secret-key

# CN: S3_SECRET_KEY 的兼容别名。如果设置了 S3_SECRET_KEY，通常不需要设置这个。
# EN: Compatibility alias for S3_SECRET_KEY. Usually not needed when S3_SECRET_KEY is set.
S3_API_KEY=

# CN: 当前活跃数据 prefix。不同环境/数据集应使用不同 prefix。
# EN: Active data prefix. Use different prefixes for different environments or datasets.
S3_PREFIX=dumbpad

# CN: 数据空间选择器的根命名空间，只列出属于本应用的 prefix。
# EN: Root namespace for the data-space picker; limits listing to this app's prefixes.
S3_SPACE_ROOT=dumbpad

# -----------------------------------------------------------------------------
# Syntax Highlighting / 代码高亮
# -----------------------------------------------------------------------------

# CN: 预加载的代码语言列表，多个值用英文逗号分隔；留空表示使用默认语言集。
# EN: Preloaded syntax-highlight languages, comma-separated. Leave empty to use the default set.
HIGHLIGHT_LANGUAGES=

# -----------------------------------------------------------------------------
# AI Provider / AI 服务
# -----------------------------------------------------------------------------

# CN: Chat/抽取模型 API 地址，需兼容 OpenAI Chat Completions。
# EN: Chat/extraction API base URL. Must be OpenAI Chat Completions compatible.
AI_BASE_URL=https://example.com/v1

# CN: Chat/抽取模型 API Key。留空会使用 noop provider，不阻塞保存。
# EN: Chat/extraction API key. Leave empty to use the noop provider; saves will not be blocked.
AI_API_KEY=

# CN: Chat/抽取模型名称。
# EN: Chat/extraction model name.
AI_CHAT_MODEL=deepseek-v4-flash

# CN: AI_BASE_URL 的兼容别名，适配旧 OpenCode 配置。
# EN: Compatibility alias for AI_BASE_URL, used by older OpenCode-style config.
OPENCODE_BASE_URL=

# CN: AI_API_KEY 的兼容别名。
# EN: Compatibility alias for AI_API_KEY.
OPENCODE_API_KEY=

# CN: AI_CHAT_MODEL 的兼容别名。
# EN: Compatibility alias for AI_CHAT_MODEL.
OPENCODE_MODEL=

# CN: Embedding API 地址，需兼容 OpenAI Embeddings。
# EN: Embedding API base URL. Must be OpenAI Embeddings compatible.
AI_EMBEDDING_BASE_URL=https://example.com/v1

# CN: Embedding API Key。留空则不生成真实 embedding。
# EN: Embedding API key. Leave empty to skip real embeddings.
AI_EMBEDDING_API_KEY=

# CN: Embedding 模型名称。
# EN: Embedding model name.
AI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# CN: SiliconFlow 兼容 base URL，也可作为 embedding/rerank 的别名来源。
# EN: SiliconFlow-compatible base URL; can be used as an alias source for embedding/rerank.
SILICON_BASE_URL=https://api.siliconflow.cn/v1

# CN: SiliconFlow API Key，可作为 embedding/rerank 的兼容别名。
# EN: SiliconFlow API key; compatibility alias for embedding/rerank keys.
SILICON_API_KEY=

# CN: AI_EMBEDDING_MODEL 的 SiliconFlow 兼容别名。
# EN: SiliconFlow compatibility alias for AI_EMBEDDING_MODEL.
SILICON_EMBEDDING_MODEL=

# CN: Rerank API 地址，用于候选关系重排。
# EN: Rerank API base URL, used to rerank relation candidates.
AI_RERANK_BASE_URL=https://api.siliconflow.cn/v1

# CN: Rerank API Key。留空则跳过真实 rerank。
# EN: Rerank API key. Leave empty to skip real reranking.
AI_RERANK_API_KEY=

# CN: Rerank 模型名称。
# EN: Rerank model name.
AI_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# CN: AI_RERANK_BASE_URL 的 SiliconFlow 兼容别名。
# EN: SiliconFlow compatibility alias for AI_RERANK_BASE_URL.
SILICON_RERANK_BASE_URL=

# CN: AI_RERANK_MODEL 的 SiliconFlow 兼容别名。
# EN: SiliconFlow compatibility alias for AI_RERANK_MODEL.
SILICON_RERANK_MODEL=

# CN: 单次 AI provider 请求超时时间，单位毫秒。
# EN: Timeout for a single AI provider request, in milliseconds.
AI_TIMEOUT_MS=60000

# CN: AI 队列并发数。过高可能触发 provider 限流。
# EN: AI queue concurrency. Too high may trigger provider rate limits.
AI_QUEUE_CONCURRENCY=3

# CN: pending AI 任务多久后视为可恢复，单位毫秒。
# EN: Age after which pending AI jobs are considered recoverable, in milliseconds.
AI_PENDING_RECOVERY_MS=120000

# CN: AI backfill 脚本最大运行时间，单位毫秒。
# EN: Maximum runtime for the AI backfill script, in milliseconds.
AI_BACKFILL_TIMEOUT_MS=900000
